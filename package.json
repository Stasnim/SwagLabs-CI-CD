{
  "name": "qa-online-shop-fsljgi",
  "version": "1.0.0",
  "description": "The assignment is to write automated test cases for an online shop to test the core functionality of the site.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report reports/html",
    "test:standard": "playwright test --grep @standard",
    "test:locked": "playwright test --grep @locked",
    "test:problem": "playwright test --grep @problem",
    "test:performance": "playwright test --grep @performance",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "http://frontline-dat-qyfgod@git.codesubmit.io/frontline-data-solutions/qa-online-shop-fsljgi"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "directories": {
    "test": "tests"
  }
}
